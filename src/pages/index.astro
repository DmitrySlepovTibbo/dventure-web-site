---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Dventure LLC</title>
  </head>
  <body class="grid min-h-screen place-items-center bg-white text-slate-900">
    <div class="flex flex-col items-center gap-8 px-6">
      <img
        src="/logo.svg"
        alt="Dventure LLC logo"
        width="1282"
        height="1227"
        class="h-40 w-auto sm:h-56 lg:h-72"
      />
      <h1 class="text-center text-6xl font-bold tracking-tight sm:text-8xl lg:text-9xl">
        Dventure LLC
      </h1>
    </div>
  </body>
</html>
